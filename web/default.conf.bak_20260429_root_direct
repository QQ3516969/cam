server {
  listen 80;
  server_name _;

  root /usr/share/nginx/html;
  index index.html;

  # Root is only a convenience entry. Real services live under explicit paths
  # such as /cam, /xxx, etc. Do not let unknown paths fall through to /cam.
  location = / {
    return 302 /cam;
  }

  location / {
    default_type text/plain;
    return 404 "service path is not configured on c6666.com
";
  }

  location /cam/api/ {
    proxy_pass http://cam-api:5000/api/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
  }

  location = /cam {
    add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0" always;
    add_header Pragma "no-cache" always;
    expires -1;
    try_files /index.html =404;
  }

  location = /cam/ {
    add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0" always;
    add_header Pragma "no-cache" always;
    expires -1;
    try_files /index.html =404;
  }

  location /cam/ {
    add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0" always;
    add_header Pragma "no-cache" always;
    expires -1;
    try_files $uri $uri/ /index.html;
  }

  location /api/ {
    proxy_pass http://cam-api:5000/api/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
  }

  location /health {
    proxy_pass http://cam-api:5000/health;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
  }
}
