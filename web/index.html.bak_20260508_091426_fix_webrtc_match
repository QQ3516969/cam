  </div>


  <script src="/cam/reader.js"></script>
  <script>
    const statusEl = document.getElementById('status');
    const videoStatusEl = document.getElementById('videoStatus');
    const padBtn = document.getElementById('padBtn');
    const videoShell = document.getElementById('videoShell');
    const padOverlay = document.getElementById('padOverlay');
    const liveDot = document.getElementById('liveDot');
    const liveText = document.getElementById('liveText');
    const latencyText = document.getElementById('latencyText');
    const webrtcFrame = document.getElementById('webrtcFrame');
    const debugPanel = document.getElementById('debugPanel');
    const debugLog = document.getElementById('debugLog');
    const debugToggleBtn = document.getElementById('debugToggleBtn');
    const IS_WECHAT = /MicroMessenger/i.test(navigator.userAgent || '');

    let padVisible = false;
    const FIXED_WEBRTC_URL = location.origin + '/cam/?controls=0&muted=1&autoplay=1&playsinline=1';
    const FIXED_STREAM_URL = FIXED_WEBRTC_URL;
    let currentStreamUrl = FIXED_STREAM_URL;
    let ignoreClickUntil = 0;
    let autoStartRetries = 0;
    const MAX_AUTOSTART_RETRIES = 30;
    let streamHealthTimer = null;
    let playbackGuardTimer = null;
    let lastVideoTime = -1;
    let stillCount = 0;
    let noSourceReloadCount = 0;
    let debugVisible = false;
    let webrtcReader = null;
    let webrtcRetryTimer = null;
    let webrtcRetryCount = 0;
    let webrtcUserActivated = false;
    let webrtcHasTrack = false;
    let webrtcStartInProgress = false;
    let webrtcStartWatchdog = null;
    let webrtcEnsureTimer = null;
    const API_BASE = location.pathname.startsWith('/cam') ? '/cam/api' : '/api';


    function setVideoStatus(text) {
      if (!videoStatusEl) return;
      const v = (text || '').trim();
      videoStatusEl.textContent = v;
      videoStatusEl.style.display = v ? 'block' : 'none';
    }

    function t(s){
      const map = {
        noStream: '\u672A\u9009\u62E9\u89C6\u9891\u6D41',
        cannotEmbed: '',
        videoErr: '\u89C6\u9891\u9519\u8BEF\uFF1A',
        sending: '\u53D1\u9001\u4E2D\uFF1A',
        success: '\u6210\u529F\uFF1A',
        failed: '\u5931\u8D25\uFF1A',
        error: '\u9519\u8BEF\uFF1A',
        missCfg: '\u63A7\u5236\u63A5\u53E3\u672A\u914D\u7F6E\uFF1A\u8BF7\u586B\u5199TUYA_CLIENT_ID / TUYA_CLIENT_SECRET / TUYA_DEVICE_ID / TUYA_REMOTE_ID',
        pad: '\u6447\u6746',
        hidePad: '\u9690\u85CF\u6447\u6746'
      };
      return map[s] || s;
    }

    function isWebRtcPlayableUrl(url) {
      return url.includes(':8889/cam/');
    }
    function normalizeToWebRtcPage(url) {
      if (!isWebRtcPlayableUrl(url)) return url;
      const base = url.split('?')[0].replace(/\/$/, '') + '/';
      return base + '?controls=0&muted=1&autoplay=1&playsinline=1';
    }
    function isCurrentWebRtcMode() {
      return isWebRtcPlayableUrl(currentStreamUrl || '');
    }

    function stopWebRtcReader() {
      if (webrtcRetryTimer) {
        clearTimeout(webrtcRetryTimer);
        webrtcRetryTimer = null;
      }
      if (webrtcStartWatchdog) {
        clearTimeout(webrtcStartWatchdog);
        webrtcStartWatchdog = null;
      }
      webrtcStartInProgress = false;
      if (webrtcReader) {
        try { webrtcReader.close(); } catch (_) {}
        webrtcReader = null;
      }
    }

    function scheduleWebRtcRetry() {
      if (!isCurrentWebRtcMode()) return;
      if (webrtcRetryTimer) return;
      const delay = webrtcUserActivated ? 900 : Math.min(8000, 1200 + webrtcRetryCount * 800);
      webrtcRetryCount += 1;
      appendDebug(`[webrtc] retry in ${delay}ms (#${webrtcRetryCount})`);
      webrtcRetryTimer = setTimeout(() => {
        webrtcRetryTimer = null;
        startWebRtcReader();
      }, delay);
    }

    function startWebRtcReader() {
      if (!isCurrentWebRtcMode()) return;
      if (webrtcStartInProgress) return;

      stopWebRtcReader();
      webrtcStartInProgress = true;
      webrtcHasTrack = false;

      const video = document.getElementById('v');
      if (!video) { webrtcStartInProgress = false; return; }

      video.muted = true;
      video.autoplay = true;
      video.playsInline = true;

      const whep = new URL('whep', FIXED_WEBRTC_URL).toString();
      try {
        webrtcReader = new MediaMTXWebRTCReader({
          url: whep,
          onError: (err) => {
            webrtcStartInProgress = false;
            appendDebug(`[webrtc] error: ${err}`);
            setLiveState('bad', '重连中');
            scheduleWebRtcRetry();
          },
          onTrack: (evt) => {
            webrtcStartInProgress = false;
            webrtcHasTrack = true;
            webrtcRetryCount = 0;
            video.srcObject = evt.streams[0];
            const playPromise = video.play();
            if (playPromise && typeof playPromise.catch === 'function') {
              playPromise.then(() => {
                              }).catch(() => {
                              });
            }
            setLiveState('ok', 'WebRTC');
            setVideoStatus('');
          },
        });

        webrtcStartWatchdog = setTimeout(() => {
          webrtcStartWatchdog = null;
          if (!webrtcHasTrack && isCurrentWebRtcMode()) {
            webrtcStartInProgress = false;
            appendDebug('[webrtc] watchdog timeout, restart');
            try { if (webrtcReader) webrtcReader.close(); } catch (_) {}
            webrtcReader = null;
            scheduleWebRtcRetry();
          }
        }, webrtcUserActivated ? 2600 : 4200);
      } catch (e) {
        webrtcStartInProgress = false;
        appendDebug(`[webrtc] init fail: ${e?.message || e}`);
        scheduleWebRtcRetry();
      }
    }

    function keepPlaying(video) {
      video.addEventListener('pause', () => { if (!video.ended) tryPlay(video); });
    }

    function tryPlay(video, fromAuto = false) {
      const p = video.play();
      if (p && typeof p.catch === 'function') {
        p.catch(() => {
          if (fromAuto) {
          }
        });
      }
    }

    function getDefaultPlayableStream() {
      return FIXED_STREAM_URL;
    }

    function syncPresetToCurrent(_) {}

    async function probeLatencyMs() {
      const t0 = performance.now();
      const probeUrl = location.origin + '/cam/reader.js';
      try {
        await fetch(probeUrl, { mode: 'no-cors', cache: 'no-store' });
        return Math.round(performance.now() - t0);
      } catch (_) {
        return -1;
      }
    }

    function startLatencyProbe() {
      const tick = async () => {
        const ms = await probeLatencyMs();
        if (latencyText) latencyText.textContent = ms >= 0 ? `${ms}ms` : '--ms';
      };
      tick();
      setInterval(tick, 3000);
    }

    function autoStartVideo() {
      currentStreamUrl = getDefaultPlayableStream();
      syncPresetToCurrent(currentStreamUrl);
      autoStartRetries = 0;
      loadVideo(currentStreamUrl);

      const video = document.getElementById('v');
      const timer = setInterval(() => {
        autoStartRetries += 1;
        if (isCurrentWebRtcMode()) {
          clearInterval(timer);
          return;
        }
        const playing = video.readyState >= 2 && !video.paused;
        if (playing) {
          clearInterval(timer);
          return;
        }
        if (autoStartRetries >= MAX_AUTOSTART_RETRIES) {
          clearInterval(timer);
          if (video.paused) {
            setVideoStatus('自动起播耗时较长，仍在后台保活重试');
          }
          return;
        }
        loadVideo(currentStreamUrl);
      }, 1500);
    }

    function setLiveState(level, text) {
      liveText.textContent = text;
      liveDot.classList.remove('live-ok', 'live-warn', 'live-bad');
      if (level === 'ok') liveDot.classList.add('live-ok');
      else if (level === 'warn') liveDot.classList.add('live-warn');
      else liveDot.classList.add('live-bad');
    }

    function startStreamHealthMonitor() {
      const video = document.getElementById('v');
      if (streamHealthTimer) clearInterval(streamHealthTimer);
      lastVideoTime = -1;
      stillCount = 0;
      setLiveState('bad', '检测中');

      streamHealthTimer = setInterval(() => {
        if (isCurrentWebRtcMode()) {
          setLiveState('ok', 'WebRTC');
          return;
        }
        if (!video.src && !video.currentSrc) {
          setLiveState('bad', '未加载');
          return;
        }
        if (video.readyState < 2) {
          setLiveState('bad', '缓冲中');
          return;
        }

        const t = Number(video.currentTime || 0);
        if (lastVideoTime < 0) {
          lastVideoTime = t;
          setLiveState('warn', '预热中');
          return;
        }

        const dt = t - lastVideoTime;
        lastVideoTime = t;

        if (dt > 0.02) {
          stillCount = 0;
          setLiveState('ok', '实时');
          return;
        }

        stillCount += 1;
        if (stillCount >= 6) {
          setLiveState('warn', '疑似静止');
        }
      }, 1000);
    }

    function startPlaybackGuard() {
      const video = document.getElementById('v');
      if (playbackGuardTimer) clearInterval(playbackGuardTimer);

      playbackGuardTimer = setInterval(() => {
        if (isCurrentWebRtcMode()) {
          const v = document.getElementById('v');
          if (v && v.paused) {
            const p = v.play();
            if (p && typeof p.catch === 'function') {
              p.catch(() => {});
            }
          }
          if (!webrtcHasTrack && webrtcUserActivated) {
            scheduleWebRtcRetry();
          }
          return;
        }
        const noSource = !video.currentSrc && !video.src;
        const stalled = video.readyState < 2 || video.paused;

        if (noSource) {
          noSourceReloadCount += 1;
          if (noSourceReloadCount >= 3) {
            if (!currentStreamUrl) {
              currentStreamUrl = getDefaultPlayableStream();
              syncPresetToCurrent(currentStreamUrl);
            }
            loadVideo(currentStreamUrl);
            noSourceReloadCount = 0;
          }
          return;
        }

        noSourceReloadCount = 0;

        if (stalled) {
          tryPlay(video, true);
          return;
        }

        const t = Number(video.currentTime || 0);
        if (lastVideoTime >= 0 && (t - lastVideoTime) <= 0.001) {
          tryPlay(video, true);
        }
      }, 3000);
    }

    function loadVideo(url) {
      const video = document.getElementById('v');
      keepPlaying(video);
      const target = url || currentStreamUrl;
      if (!target) { setVideoStatus(t('noStream')); return; }

      video.pause();
      video.removeAttribute('src');
      video.load();

      if (isWebRtcPlayableUrl(target)) {
        currentStreamUrl = FIXED_WEBRTC_URL;
        webrtcHasTrack = false;
        if (webrtcFrame) {
          webrtcFrame.style.display = 'none';
          webrtcFrame.style.pointerEvents = 'none';
          webrtcFrame.src = 'about:blank';
        }
        video.style.display = 'block';
        setVideoStatus('正在连接 WebRTC...');
        startWebRtcReader();
        return;
      }

      stopWebRtcReader();
      if (webrtcFrame) {
        webrtcFrame.style.display = 'none';
        webrtcFrame.style.pointerEvents = 'none';
        webrtcFrame.src = 'about:blank';
      }
      video.style.display = 'block';
      setVideoStatus('仅启用 WebRTC');
    }

    function applyStream() {
      currentStreamUrl = FIXED_STREAM_URL;
      loadVideo(currentStreamUrl);
    }
    function openStream() { window.open(FIXED_STREAM_URL, '_blank'); }

    function nowStamp() {
      return new Date().toLocaleTimeString();
    }

    function appendDebug(line) {
      if (!debugLog) return;
      const prev = debugLog.textContent || '';
      const next = `${nowStamp()} ${line}`;
      const merged = prev ? `${prev}\n${next}` : next;
      const lines = merged.split('\n');
      debugLog.textContent = lines.slice(-120).join('\n');
      if (debugVisible && debugPanel) debugPanel.scrollTop = debugPanel.scrollHeight;
    }

    function clearDebug() {
      if (debugLog) debugLog.textContent = '调试日志已清空';
    }

    function toggleDebug() {
      debugVisible = !debugVisible;
      if (!debugPanel || !debugToggleBtn) return;
      if (debugVisible) {
        debugPanel.classList.remove('hide');
        debugToggleBtn.textContent = '隐藏调试';
      } else {
        debugPanel.classList.add('hide');
        debugToggleBtn.textContent = '显示调试';
      }
    }

    function initUiState() {
      if (debugPanel) debugPanel.classList.add('hide');
      if (debugToggleBtn) debugToggleBtn.textContent = '显示调试';
    }

    async function warmupPlayback() {
      const video = document.getElementById('v');
      if (!video) return;
      video.muted = true;
      video.autoplay = true;
      video.playsInline = true;
      try { await video.play(); } catch (_) {}
    }

    function startAutoWebRtcBootstrap() {
      if (!isCurrentWebRtcMode()) return;
      webrtcUserActivated = true;
      warmupPlayback();
      startWebRtcReader();

      if (webrtcEnsureTimer) clearInterval(webrtcEnsureTimer);
      webrtcEnsureTimer = setInterval(() => {
        if (!isCurrentWebRtcMode()) return;
        if (webrtcHasTrack) {
          clearInterval(webrtcEnsureTimer);
          webrtcEnsureTimer = null;
          return;
        }
        startWebRtcReader();
      }, 1200);
    }

    const HOLD_KEYS = new Set([]);
    const PRESET_BURST_KEYS = new Set([
      'up', 'down', 'left', 'right',
      'zoom+', 'zoom-',
      '1', '2', '3', '4', '5', '6', '7', '8', '9', 'home',
    ]);
    const PRESET_BURST_COUNT = 5;
    const PRESET_BURST_INTERVAL_MS = 120;
    const HOLD_DURATION_MS = 8000;
    const HOLD_INTERVAL_MS = 180;
    const HOLD_MAX_INFLIGHT = 2;

    async function sendOnce(key) {
      const t0 = performance.now();
      try {
        const r = await fetch(`${API_BASE}/control`, {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ key })
        });
        const text = await r.text();
        let j = {};
        try {
          j = JSON.parse(text || '{}');
        } catch (_) {
          j = { ok: false, error: 'invalid json', raw: text };
        }
        const cost = Math.round(performance.now() - t0);
        appendDebug(`[${key}] HTTP ${r.status} ${cost}ms -> ${JSON.stringify(j)}`);
        return j;
      } catch (e) {
        const cost = Math.round(performance.now() - t0);
        const msg = e?.message || String(e);
        appendDebug(`[${key}] NETWORK ${cost}ms -> ${msg}`);
        throw e;
      }
    }

    async function sendHoldOneSecond(key) {
      const deadline = Date.now() + HOLD_DURATION_MS;
      let inflight = 0;
      let sent = 0;
      let done = false;
      let firstError = null;

      return await new Promise((resolve) => {
        const pump = () => {
          if (done) return;

          while (Date.now() < deadline && inflight < HOLD_MAX_INFLIGHT && !firstError) {
            inflight += 1;
            sent += 1;
            sendOnce(key)
              .then((j) => {
                if (!j?.ok && !firstError) firstError = j;
              })
              .catch((e) => {
                if (!firstError) firstError = { ok: false, error: e?.message || String(e) };
              })
              .finally(() => {
                inflight -= 1;
                if (done) return;
                if (firstError && inflight === 0) {
                  done = true;
                  resolve(firstError);
                  return;
                }
                if (Date.now() >= deadline && inflight === 0) {
                  done = true;
                  appendDebug(`[${key}] HOLD done, sent=${sent}`);
                  resolve({ ok: true, key, sent });
                }
              });
          }

          if (Date.now() >= deadline && inflight === 0) {
            done = true;
            appendDebug(`[${key}] HOLD done, sent=${sent}`);
            resolve({ ok: true, key, sent });
            return;
          }

          if (!done) setTimeout(pump, HOLD_INTERVAL_MS);
        };

        pump();
      });
    }

    async function sendPresetBurst(key) {
      let last = null;
      for (let i = 0; i < PRESET_BURST_COUNT; i += 1) {
        last = await sendOnce(key);
        if (!last?.ok) return last;
        if (i < PRESET_BURST_COUNT - 1) {
          await new Promise(resolve => setTimeout(resolve, PRESET_BURST_INTERVAL_MS));
        }
      }
      appendDebug(`[${key}] BURST done, sent=${PRESET_BURST_COUNT}`);
      return last || { ok: true };
    }

    async function send(key) {
      statusEl.textContent = t('sending') + key + '...';
      try {
        const j = HOLD_KEYS.has(key)
          ? await sendHoldOneSecond(key)
          : (PRESET_BURST_KEYS.has(key) ? await sendPresetBurst(key) : await sendOnce(key));
        if (j.ok) statusEl.textContent = t('success') + key;
        else if (j.error === 'missing config') statusEl.textContent = t('missCfg');
        else statusEl.textContent = t('failed') + JSON.stringify(j);
      } catch (e) {
        statusEl.textContent = t('error') + e.message;
      }
    }


    function isFullscreen() { return !!(document.fullscreenElement || document.webkitFullscreenElement); }
    async function toggleFullscreen() {
      if (!isFullscreen()) {
        try {
          if (videoShell.requestFullscreen) await videoShell.requestFullscreen();
          else if (videoShell.webkitRequestFullscreen) videoShell.webkitRequestFullscreen();
        } catch (_) {}
      } else {
        if (document.exitFullscreen) await document.exitFullscreen();
        else if (document.webkitExitFullscreen) document.webkitExitFullscreen();
      }
    }

    function togglePad() {
      ignoreClickUntil = Date.now() + 300;
      padVisible = !padVisible;
      if (padVisible) padOverlay.classList.add('show'); else padOverlay.classList.remove('show');
      padBtn.textContent = padVisible ? t('hidePad') : t('pad');
    }

    function handleVideoShellClick(ev) {
      if (Date.now() < ignoreClickUntil) return;
      const t = ev.target;
      if (!t) return;
      if (t.closest('button') || t.closest('.video-toolbar') || t.closest('.fs-overlay') || t.closest('.stream-bar')) return;
      toggleFullscreen();
    }

    videoShell.addEventListener('click', handleVideoShellClick);
    const video = document.getElementById('v');
    video.muted = true;
    video.autoplay = true;
    video.playsInline = true;

    video.addEventListener('click', () => tryPlay(video), { passive: true });
    video.addEventListener('loadedmetadata', () => tryPlay(video, true));
    video.addEventListener('canplay', () => tryPlay(video, true));
    video.addEventListener('stalled', () => tryPlay(video, true));
    video.addEventListener('waiting', () => tryPlay(video, true));

    window.addEventListener('beforeunload', () => {
      stopWebRtcReader();
      if (webrtcEnsureTimer) clearInterval(webrtcEnsureTimer);
    });

    document.addEventListener('visibilitychange', () => {
      if (!document.hidden) {
        tryPlay(video);
        if (isCurrentWebRtcMode() && !webrtcHasTrack) startAutoWebRtcBootstrap();
      }
    });

    // WeChat privileged event: improves autoplay/WebRTC startup success without manual taps.
    document.addEventListener('WeixinJSBridgeReady', () => {
      if (isCurrentWebRtcMode() && !webrtcHasTrack) {
        startAutoWebRtcBootstrap();
      }
    });

    initUiState();
    setVideoStatus('');
    autoStartVideo();
    startAutoWebRtcBootstrap();
    startStreamHealthMonitor();
    startPlaybackGuard();
    startLatencyProbe();
  </script>
</body>
</html>
