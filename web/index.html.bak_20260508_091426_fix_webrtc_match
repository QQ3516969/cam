  </script>
  <style>
    :root {
      --bg: #0b0d12;
      --panel: #151922;
      --panel-border: #2b3342;
      --btn: #2a3140;
      --btn-border: #3b4558;
      --btn-text: #eef2ff;
      --ok: #2ea55f;
      --ok-border: #46bf79;
      --shadow: 0 8px 24px rgba(0,0,0,0.35);
    }
    * { box-sizing: border-box; }
    body { margin:0; background: #0f131a; color:#f2f5ff; font-family:-apple-system,BlinkMacSystemFont,"SF Pro Text","PingFang SC","Microsoft YaHei",sans-serif; }
    .wrap { max-width:980px; margin:0 auto; padding:10px; padding-bottom:64px; }
    .card { background:var(--panel); border:1px solid var(--panel-border); border-radius:14px; padding:8px; margin-bottom:8px; }
    .video-card { overflow:hidden; }
    .video-shell { position:relative; width:100%; max-width:100%; box-sizing:border-box; border-radius:14px; overflow:hidden; background:#000; border:1px solid #2b3342; aspect-ratio:16/9; min-height:220px; isolation:isolate; -webkit-transform:translateZ(0); transform:translateZ(0); }
    video { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; display:block; background:#000; -webkit-user-select:none; user-select:none; touch-action:manipulation; border-radius:inherit; clip-path:inset(0 round 14px); }
    .webrtc-frame { position:absolute; inset:0; width:100%; height:100%; border:0; background:#000; display:none; z-index:25; pointer-events:none; border-radius:inherit; clip-path:inset(0 round 14px); }
    video::-webkit-media-controls { display:none !important; }
    video::-webkit-media-controls-enclosure { display:none !important; }
    .live-badge { position:absolute; right:8px; bottom:8px; height:20px; line-height:20px; padding:0 7px; border-radius:999px; font-size:10px; color:#fff; background:rgba(0,0,0,0.55); border:1px solid rgba(255,255,255,0.20); letter-spacing:0.2px; z-index:30; display:flex; align-items:center; gap:5px; }
    #liveText { display:none; }
    .live-dot { width:7px; height:7px; border-radius:50%; display:inline-block; }
    .live-ok { background:#2ecc71; box-shadow:0 0 0 2px rgba(46,204,113,0.2); }
    .live-warn { background:#f1c40f; box-shadow:0 0 0 2px rgba(241,196,15,0.2); }
    .live-bad { background:#ff4d4f; box-shadow:0 0 0 2px rgba(255,77,79,0.2); }
    .video-toolbar { position:absolute; top:8px; right:8px; z-index:31; display:none; gap:6px; }
    .apple-btn { border:1px solid var(--btn-border); background:var(--btn); color:var(--btn-text); border-radius:10px; transition: background-color .08s ease, border-color .08s ease; font-weight:600; }
    .apple-btn:active { transform:none; background: #3a475e; border-color:#567099; }
    .tiny { height:28px; padding:0 8px; font-size:11px; border-radius:9px; }
    .status { min-height:18px; margin-top:8px; font-size:12px; color:#a7c5ff; letter-spacing:.1px; }
    .video-status { min-height:0; margin-top:0; }
    .controls-layout { display:grid; grid-template-columns:1fr 1fr; gap:10px; align-items:start; }
    .left-stack { display:flex; flex-direction:column; gap:10px; }
    .panel-box { border:1px solid rgba(202,220,255,0.34); border-radius:16px; padding:10px; background: radial-gradient(circle at 20% 20%, rgba(72,118,179,0.20), rgba(17,24,36,0.88) 55%), linear-gradient(160deg, rgba(39,48,66,0.88), rgba(14,20,30,0.94)); box-shadow: inset 0 0 0 1px rgba(255,255,255,0.05), 0 10px 22px rgba(0,0,0,0.32); }
    .panel-title { text-align:center; font-size:17px; font-weight:700; margin-bottom:10px; color:#edf3ff; letter-spacing:1px; text-shadow:0 1px 2px rgba(0,0,0,0.45); }
    .panel-subtitle { font-size:12px; color:#a9bcdb; margin:0 0 8px; text-align:center; }
    .ctl-btn { height:40px; font-size:14px; border-radius:12px; }
    .preset-btn { opacity:.68; background:#242c3a; border-color:#35425a; color:#c7d3ea; font-weight:500; }
    .preset-btn:active { opacity:.92; }
    .ok-btn { background:var(--ok); border-color:var(--ok-border); color:#f8fffb; font-weight:700; }
    .dir-btn { background:#2b5fd9; border-color:#4b7df2; color:#eef4ff; }
    .dir-btn:active { background:#4a79ea; border-color:#7aa0ff; color:#ffffff; }
    .joy-up, .joy-down, .joy-left, .joy-right { background:#2b5fd9; border-color:#4b7df2; }
    .joy-up:active, .joy-down:active, .joy-left:active, .joy-right:active { background:#4a79ea; border-color:#7aa0ff; }
    .ctl-btn:active { transform:none; background: linear-gradient(180deg, rgba(96,132,190,0.95), rgba(74,106,165,0.95)); border-color: rgba(194,222,255,0.58); color:#ffffff; }
    .ctl-btn.dir-btn:active { background:#4a79ea; border-color:#7aa0ff; color:#ffffff; }
    .ok-btn:active { transform:none; background: linear-gradient(180deg, #2fbe66, #269d55); border-color: rgba(132,255,178,0.68); color:#ffffff; }
    .joy-center:active { transform: translate(-50%,-50%) !important; background:#259653; border-color:#46bf79; }
    .preset-grid { display:grid; grid-template-columns:repeat(2, minmax(0, 1fr)); gap:8px; }
    .extra-grid { margin-top:10px; display:grid; grid-template-columns:repeat(3, minmax(0, 1fr)); gap:7px; }
    .extra-btn { height:34px; font-size:13px; border-radius:10px; background:#202735; border-color:#38465e; color:#d7e4ff; }
    .extra-btn:active { background:#2e3a4f; border-color:#567099; }
    .home-btn { grid-column:1 / -1; height:36px; font-weight:700; }
    .func-grid { display:grid; grid-template-columns:repeat(2, minmax(0, 1fr)); gap:8px; }
    .center-core { border-radius:32px; display:flex; flex-direction:column; align-items:center; justify-content:center; }
    .core-rim { width:226px; height:226px; border-radius:50%; position:relative; background: radial-gradient(circle at 32% 24%, rgba(98,114,140,0.64), rgba(27,34,48,0.96) 60%, rgba(11,15,22,0.98) 100%); border:1px solid rgba(198,216,250,0.30); box-shadow: inset 0 6px 18px rgba(255,255,255,0.12), inset 0 -10px 18px rgba(0,0,0,0.5), 0 12px 22px rgba(0,0,0,0.42); }
    .core-rim::before { content:""; position:absolute; inset:13px; border-radius:50%; border:1px solid rgba(200,216,243,0.16); }
    .core-btn { position:absolute; min-width:72px; height:42px; padding:0 12px; }
    .dir-up { left:50%; top:12px; transform:translateX(-50%); }
    .dir-down { left:50%; bottom:12px; transform:translateX(-50%); }
    .dir-left { left:10px; top:50%; transform:translateY(-50%); }
    .dir-right { right:10px; top:50%; transform:translateY(-50%); }
    .core-ok { left:50%; top:50%; transform:translate(-50%, -50%); width:84px; height:84px; border-radius:50%; font-size:24px; box-shadow: inset 0 0 0 2px rgba(255,255,255,0.14), 0 8px 16px rgba(0,0,0,0.4); }
    .fs-overlay { position:absolute; left:0; right:0; bottom:max(8px, env(safe-area-inset-bottom)); display:none; z-index:40; padding:0 8px; pointer-events:none; }
    .fs-overlay.show { display:block; }
    .joy-wrap { width:min(420px, 90vw); margin: 8px auto 0; pointer-events:auto; }
    .joy-stack { display:flex; flex-direction:column; align-items:center; gap:8px; }
    .joystick { position:relative; width:min(190px, 46vw); height:min(190px, 46vw); margin:0 auto; border-radius:50%; background:#1a202b; border:1px solid #3a4558; }
    .joy-btn { position:absolute; width:46px; height:46px; border-radius:50%; font-size:12px; border:1px solid #4a556b; background:#232b39; color:#fff; display:flex; align-items:center; justify-content:center; touch-action:manipulation; }
    .joy-btn:active { background:#415273; border-color:#6f87b8; }
    .joy-up { left:50%; top:10px; transform:translateX(-50%); }
    .joy-down { left:50%; bottom:10px; transform:translateX(-50%); }
    .joy-left { left:10px; top:50%; transform:translateY(-50%); }
    .joy-right { right:10px; top:50%; transform:translateY(-50%); }
    .joy-center { left:50%; top:50%; transform:translate(-50%,-50%); width:56px; height:56px; background:var(--ok); border-color:var(--ok-border); font-weight:700; margin:0; }
    .joy-zoom-plus { left:40px; bottom:22px; transform:none; width:30px; height:20px; border-radius:10px; font-size:10px; }
    .joy-zoom-minus { right:40px; bottom:22px; transform:none; width:30px; height:20px; border-radius:10px; font-size:10px; }
            .stream-bar { display:none !important; }
    .stream-bar select { height:30px; border-radius:8px; border:1px solid #3b4558; background:#111722; color:#dde7ff; padding:0 7px; font-size:10px; }
    .stream-bar button { height:30px; font-size:10px; padding:0 8px; border-radius:8px; }
    .debug-row { display:flex; gap:6px; margin-top:8px; }
    .debug-toggle { height:28px; padding:0 10px; font-size:11px; border-radius:8px; }
    .debug-panel { margin-top:8px; border:1px solid #2f394b; border-radius:10px; background:#0f1420; padding:6px; max-height:180px; overflow:auto; }
    .debug-panel.hide { display:none; }
    .debug-log { margin:0; white-space:pre-wrap; word-break:break-word; font-size:11px; line-height:1.35; color:#cfe2ff; }
    .start-btn { position:absolute; left:50%; top:50%; transform:translate(-50%,-50%); z-index:35; min-width:140px; height:36px; padding:0 14px; display:none; }
    .video-shell:fullscreen .fs-overlay.show, .video-shell:-webkit-full-screen .fs-overlay.show { display:block; }
    .video-shell:fullscreen, .video-shell:-webkit-full-screen { width:100vw; height:100vh; border-radius:0; border:none; }
    .video-shell:fullscreen video, .video-shell:-webkit-full-screen video { width:100%; height:100%; object-fit:cover; }
    .video-shell:fullscreen .video-toolbar, .video-shell:-webkit-full-screen .video-toolbar { display:flex; }
    @media (max-width:760px) {
      .controls-layout { grid-template-columns:1fr; gap:8px; }
      .ctl-btn { height:36px; font-size:13px; }
      .panel-title { margin-bottom:8px; font-size:16px; }
      .preset-grid, .func-grid { gap:6px; }
      .center-core { order:0; border-radius:18px; padding:10px; }
      .core-rim { width:200px; height:200px; }
      .core-btn { min-width:64px; height:38px; }
      .core-ok { width:74px; height:74px; font-size:22px; }
      .joy-wrap { width:min(340px, 92vw); margin-top: 10px; }
      .joystick { width:min(164px, 44vw); height:min(164px, 44vw); }
      .joy-btn { width:40px; height:40px; font-size:11px; }
      .joy-center { width:50px; height:50px; font-size:11px; }
      .joy-zoom-plus, .joy-zoom-minus { width:28px; height:18px; font-size:9px; bottom:20px; }
      .video-shell { aspect-ratio:16/9; min-height:220px; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="card video-card">
      <div id="videoShell" class="video-shell">
        <div id="liveBadge" class="live-badge"><span id="liveDot" class="live-dot live-bad"></span><span id="liveText">检测中</span><span id="latencyText">--ms</span></div>
        <div class="video-toolbar">
          <button class="apple-btn tiny" onclick="togglePad()" id="padBtn">&#x25CE;</button>
        </div>

        <video id="v" autoplay muted playsinline webkit-playsinline></video>
        <iframe id="webrtcFrame" class="webrtc-frame" allow="autoplay; fullscreen"></iframe>
        
        <div class="fs-overlay" id="padOverlay">
          <div class="joy-wrap">
            <div class="joy-stack">
              <div class="joystick">
                <button class="joy-btn joy-up" onclick="send('up')">&#x4E0A;</button>
                <button class="joy-btn joy-down" onclick="send('down')">&#x4E0B;</button>
                <button class="joy-btn joy-left" onclick="send('left')">&#x5DE6;</button>
                <button class="joy-btn joy-right" onclick="send('right')">&#x53F3;</button>
                <button class="joy-btn joy-zoom-plus" onclick="send('zoom+')">+</button>
                <button class="joy-btn joy-zoom-minus" onclick="send('zoom-')">-</button>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="status video-status" id="videoStatus"></div>
    </div>

    <div class="card">
      <div class="controls-layout">
        <div class="left-stack">
          <div class="panel-box">
            <div class="panel-title">预置控制</div>
            <p class="panel-subtitle">一键触达常用机位</p>
            <div class="extra-grid">
              <button class="apple-btn extra-btn" onclick="send('1')">1</button>
              <button class="apple-btn extra-btn" onclick="send('2')">2</button>
              <button class="apple-btn extra-btn" onclick="send('3')">3</button>
              <button class="apple-btn extra-btn" onclick="send('4')">4</button>
              <button class="apple-btn extra-btn" onclick="send('5')">5</button>
              <button class="apple-btn extra-btn" onclick="send('6')">6</button>
              <button class="apple-btn extra-btn" onclick="send('7')">7</button>
              <button class="apple-btn extra-btn" onclick="send('8')">8</button>
              <button class="apple-btn extra-btn" onclick="send('9')">9</button>
              <button class="apple-btn extra-btn home-btn" onclick="send('home')">Home</button>
            </div>
          </div>

          <div class="panel-box center-core">
            <div class="panel-title">视角控制</div>
            <div class="core-rim">
              <button class="apple-btn ctl-btn dir-btn core-btn dir-up" onclick="send('up')">&#x4E0A;</button>
              <button class="apple-btn ctl-btn dir-btn core-btn dir-left" onclick="send('left')">&#x5DE6;</button>
              <button class="apple-btn ctl-btn dir-btn core-btn dir-right" onclick="send('right')">&#x53F3;</button>
              <button class="apple-btn ctl-btn dir-btn core-btn dir-down" onclick="send('down')">&#x4E0B;</button>
            </div>
          </div>
        </div>

        <div class="panel-box">
          <div class="panel-title">镜头控制</div>
          <p class="panel-subtitle">快速变焦</p>
          <div class="func-grid">
            <button class="apple-btn ctl-btn" onclick="send('zoom+')">&#x53D8;&#x7126;+</button>
            <button class="apple-btn ctl-btn" onclick="send('zoom-')">&#x53D8;&#x7126;-</button>
          </div>
        </div>
      </div>
      <div class="status" id="status"></div>
      <div class="debug-row">
        <button class="apple-btn debug-toggle" id="debugToggleBtn" onclick="toggleDebug()">隐藏调试</button>
        <button class="apple-btn debug-toggle" onclick="clearDebug()">清空调试</button>
      </div>
      <div class="debug-panel" id="debugPanel">
        <pre class="debug-log" id="debugLog">调试日志已开启</pre>
      </div>
